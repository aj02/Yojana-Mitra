# DeepInfra — get a key at https://deepinfra.com → API keys
DEEPINFRA_API_KEY=

# Upstash Redis (free tier) — https://console.upstash.com → create Redis DB
# Used for rate limiting the /api/schemes route. Without these, the limiter is disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — used in sitemap.ts
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
